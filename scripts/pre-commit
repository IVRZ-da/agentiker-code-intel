#!/usr/bin/env bash
# pre-commit hook for agentiker-code-intel-plugin
# Runs: syntax check, selective tests, coverage threshold, version consistency
# Install: ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'
PLUGIN_DIR="$(cd "$(dirname "$0")/.." && pwd)"
cd "$PLUGIN_DIR"

FAILED=0

echo "=== Pre-Commit Hook: code-intel-plugin ==="

# 1. Syntax check all Python files
echo -n "1. Python syntax check..."
if python3 -c "
import ast, os, sys
errors = []
for root, dirs, files in os.walk('.'):
    for f in files:
        if f.endswith('.py') and '/.' not in root and '__pycache__' not in root:
            path = os.path.join(root, f)
            try:
                ast.parse(open(path).read())
            except SyntaxError as e:
                errors.append(f'{path}: {e}')
if errors:
    print('\\n' + '\\n'.join(errors[:10]))
    sys.exit(1)
" 2>&1; then
    echo -e " ${GREEN}OK${NC}"
else
    echo -e " ${RED}FAILED${NC}"
    FAILED=1
fi

# 2. Ruff lint
echo -n "2. Ruff lint..."
if python3 -m ruff check . --quiet 2>&1; then
    echo -e " ${GREEN}OK${NC}"
else
    echo -e " ${RED}ISSUES FOUND${NC}"
    FAILED=1
fi

# 3. Selective tests based on changed files
STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || echo "")
if [ -n "$STAGED" ]; then
    echo "3. Changed files: $(echo "$STAGED" | wc -l) files"

    # Determine test scope
    TEST_TARGETS=""
    if echo "$STAGED" | grep -q "code_tools\|tools/"; then
        TEST_TARGETS="$TEST_TARGETS tests/test_code_intel_tools.py"
    fi
    if echo "$STAGED" | grep -q "lsp/"; then
        TEST_TARGETS="$TEST_TARGETS tests/test_lsp_bridge_ops.py tests/test_lsp_gaps.py"
    fi
    if echo "$STAGED" | grep -q "_import_graph\|tools/graph"; then
        TEST_TARGETS="$TEST_TARGETS tests/test_import_graph.py tests/test_code_dependency_graph.py"
    fi
    if echo "$STAGED" | grep -q "__init__\|tools/"; then
        TEST_TARGETS="$TEST_TARGETS tests/test_tool_profiles.py"
    fi

    if [ -n "$TEST_TARGETS" ]; then
        echo -n "   Running: $TEST_TARGETS..."
        if python3 -m pytest $TEST_TARGETS -q --no-header --timeout=60 2>&1 | tail -3; then
            echo -e " ${GREEN}Tests OK${NC}"
        else
            echo -e " ${RED}Tests FAILED${NC}"
            FAILED=1
        fi
    fi
else
    # Full test run (smaller set)
    echo -n "3. Running core tests..."
    if python3 -m pytest tests/test_code_intel.py tests/test_code_intel_tools.py tests/test_tool_profiles.py -q --no-header --timeout=60 2>&1 | tail -3; then
        echo -e " ${GREEN}Tests OK${NC}"
    else
        echo -e " ${RED}Tests FAILED${NC}"
        FAILED=1
    fi
fi

# 4. Coverage threshold (50%)
echo -n "4. Coverage check (>=50%)..."
COV_REPORT=$(python3 -m pytest tests/test_code_intel.py tests/test_code_intel_tools.py tests/test_custom_tools.py tests/test_import_graph.py -q --no-header --cov=code_intel --cov-report=term --timeout=60 2>&1 | grep "TOTAL" || echo "")
COV_PCT=$(echo "$COV_REPORT" | grep -oP '\d+(?=%)' || echo "0")
if [ "$COV_PCT" -ge 50 ] 2>/dev/null; then
    echo -e " ${GREEN}${COV_PCT}%${NC}"
else
    echo -e " ${RED}${COV_PCT}% (below 50%)${NC}"
    FAILED=1
fi

# 5. Version consistency (optional — skip if plugin.yaml missing)
echo -n "5. Version consistency..."
PLUGIN_VER=$(grep -oP 'version:\s*\K[^\s]+' plugin.yaml 2>/dev/null || echo "")
PYPROJ_VER=$(grep -oP 'version\s*=\s*"\K[^"]+' pyproject.toml 2>/dev/null || echo "")
if [ "$PLUGIN_VER" = "$PYPROJ_VER" ] && [ -n "$PLUGIN_VER" ]; then
    echo -e " ${GREEN}v${PLUGIN_VER}${NC}"
else
    echo -e " ${RED}Mismatch: plugin.yaml=$PLUGIN_VER pyproject.toml=$PYPROJ_VER${NC}"
    FAILED=1
fi

# Summary
echo "=== Summary ==="
if [ "$FAILED" -eq 0 ]; then
    echo -e "${GREEN}All checks passed${NC}"
else
    echo -e "${RED}${FAILED} check(s) failed${NC}"
fi
exit "$FAILED"
